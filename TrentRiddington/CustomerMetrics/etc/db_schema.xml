<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="customer_metrics" resource="default" engine="innodb" comment="Customer Metrics">
        <column xsi:type="int" name="customer_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Customer ID"/>
        <column xsi:type="decimal" name="lifetime_revenue" scale="4" precision="20" unsigned="false" nullable="true"
                comment="Lifetime Revenue"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="customer_id"/>
        </constraint>
        <index referenceId="CUSTOMER_SALES_DATA_METRICS_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="CUSTOMER_SALES_DATA_METRICS_LIFETIME_REVENUE" indexType="btree">
            <column name="lifetime_revenue"/>
        </index>
        <constraint xsi:type="foreign" referenceId="CUSTOMER_SALES_DATA_METRICS_FK"
                    table="customer_sales_data_metrics" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
    </table>
</schema>
